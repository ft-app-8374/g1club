# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@host:5432/group1club"

# NextAuth
NEXTAUTH_SECRET="generate-a-real-secret-here"
NEXTAUTH_URL="https://app.group1club.com"

# Betfair Exchange API
BETFAIR_API_KEY=""
BETFAIR_USERNAME=""
BETFAIR_PASSWORD=""

# Email (AWS SES)
SMTP_HOST="email-smtp.ap-southeast-2.amazonaws.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Group 1 Club <noreply@group1club.com>"

# Cron authentication
CRON_SECRET="generate-a-cron-secret"

# Competition mode — set to "true" when live to send emails to all members
# When not set or "false", only admins receive notification emails (testing mode)
COMPETITION_LIVE="false"
